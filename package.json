{
  "name": "env-form",
  "displayName": "env form",
  "description": "A visual editor for .env files that replaces raw text with a clean, user-friendly form interface.",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "envForm.customEditor",
        "displayName": "Env Editor",
        "selector": [
          {
            "filenamePattern": "*.env"
          },
          {
            "filenamePattern": "*.env.*"
          },
          {
            "filenamePattern": ".env"
          },
          {
            "filenamePattern": ".env.*"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "env-form.helloWorld",
        "title": "Hello World"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "tailwindcss": "npx tailwindcss -i src/index.css -o src/media/index.css --watch",
    "build:tailwindcss": "npx tailwindcss -i src/index.css -o src/media/index.css --minify"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NgodingCik/env-form.git"
  },
  "homepage": "https://github.com/NgodingCik/env-form#readme",
  "bugs": {
    "url": "https://github.com/NgodingCik/env-form/issues"
  }
}
